# ============================================================
# Pharmacy Pricing System — Environment Variables
# Copy this file to db.env and fill in your values
# ============================================================

# ---------- Flask ----------
# Set to 'production' on the deployed server
FLASK_ENV=development
# Set to 'true' ONLY for local development
FLASK_DEBUG=false
# Port the app listens on (Render sets this automatically)
PORT=5000

# ---------- Secrets (REQUIRED in production) ----------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
JWT_SECRET_KEY=

# ---------- Central Database ----------
CENTRAL_DB_HOST=localhost
CENTRAL_DB_PORT=5432
CENTRAL_DB_NAME=pricing_central
CENTRAL_DB_USER=postgres
CENTRAL_DB_PASSWORD=

# ---------- PostgreSQL Admin (for creating tenant DBs) ----------
PG_ADMIN_USER=postgres
PG_ADMIN_PASSWORD=
PG_ADMIN_HOST=localhost

# ---------- CORS (comma-separated origins, or * for dev) ----------
# Example: https://your-app.onrender.com,https://custom-domain.com
CORS_ORIGINS=*

# ---------- Logging ----------
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ---------- File Upload ----------
UPLOAD_FOLDER=uploads
